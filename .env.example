# ===========================================
# 프롬프트 → 콘텐츠 생성 → 트위터/네이버 게시용
# 이 파일을 복사해서 .env 만들고, 아래에 실제 값 채우기
# .env 는 Git에 올리지 마세요
# ===========================================

# --- OpenAI (콘텐츠 생성) ---
OPENAI_API_KEY=sk-...
GOOGLE_SHEET_ID=1...
# --- Perplexity (전략/인플루언서 분석 — strategy.html, unified-dashboard) ---
# project_html 백엔드에서 인플루언서·경쟁사·해시태그 실시간 검색에 사용
# console.perplexity.ai 또는 API 문서에서 발급
PERPLEXITY_API_KEY=pplx-...
# --- X (Twitter) API (트윗 게시) ---
# developer.x.com 에서 앱 생성 후 발급
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_TOKEN_SECRET=...

# --- 네이버 (블로그 API) ---
# developers.naver.com 애플리케이션 등록 후 발급
NAVER_CLIENT_ID=...
NAVER_CLIENT_SECRET=...
# OAuth 한 번 진행 후 받은 토큰 (블로그 포스트용)
NAVER_ACCESS_TOKEN=...
NAVER_REFRESH_TOKEN=...

# --- 링크트리 (생성 문구에 링크로 넣을 주소) ---
LINKTREE_URL=https://linktr.ee/yourusername

# --- Firebase (시향 테스트 10명 이상 시 자동 통계) ---
# 서비스 계정 키: santokki/firebase-key.json 에 두면 자동 연동됨 (별도 .env 변수 없음)

# --- Google Sheets (일일 프롬프트 자동 저장) ---
# 1) Google Cloud Console에서 서비스 계정 생성 → JSON 키 다운로드
# 2) 해당 JSON 내용을 한 줄로 붙여넣기 (또는 base64 등으로 저장 후 코드에서 파싱)
#    또는 google-sheets-key.json 파일로 저장 후 GOOGLE_APPLICATION_CREDENTIALS=./google-sheets-key.json
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# 저장할 스프레드시트 ID (URL의 /d/ 다음 부분)
GOOGLE_SHEET_ID=your_spreadsheet_id
# 시트 탭 이름 (기본: 일일프롬프트)
GOOGLE_SHEET_TAB_NAME=일일프롬프트
# 일일 실행용 시크릿 (선택) — POST /api/run-daily-prompts?token=xxx 로 호출 시 사용
DAILY_CRON_SECRET=your_secret_token

# --- ManyChat (퍼널 상단 2단계 숫자) ---
# ManyChat 대시보드 → Settings → Webhooks → URL에 아래 주소 등록
#   https://your-domain.com/api/manychat/webhook
# 이벤트: subscriber_added → 댓글 키워드 작성 수, message_sent → 퀴즈 링크 DM 수
# 대시보드 퍼널은 GET /api/funnel-stats 로 이 숫자를 불러와 표시함
#ㅁㄴㅇㅁㄴㅇㅁㅁ